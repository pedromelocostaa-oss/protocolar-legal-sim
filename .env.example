# ─── Supabase ───────────────────────────────────────────────────────────────
# Obtenha estes valores em: https://supabase.com → Project Settings → API

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Modo de operação ───────────────────────────────────────────────────────
# Quando VITE_SUPABASE_URL não está configurado (ou é "YOUR_SUPABASE_URL"),
# o sistema roda em MODO DEMO com dados locais (localStorage).
#
# Para produção, preencha as variáveis acima e execute a migration SQL.
